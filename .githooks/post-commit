#!/usr/bin/env bash
# Post-commit auditor.
#
# Records every commit into harness-audit.ndjson so humans can trace the
# full sequence of changes — including manual chore commits that bypass
# the harness flow. The hook is best-effort: if it fails for any reason,
# the commit still succeeds (it already landed).

set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$REPO_ROOT" ]]; then
    exit 0
fi
cd "$REPO_ROOT"

SHA="$(git rev-parse HEAD 2>/dev/null || echo '')"
SUBJECT="$(git log -1 --format='%s' 2>/dev/null || echo '')"
AUTHOR="$(git log -1 --format='%an <%ae>' 2>/dev/null || echo '')"
FILES_JSON="$(git show --pretty='' --name-only HEAD 2>/dev/null | \
    python3 -c 'import json,sys; print(json.dumps([l.rstrip() for l in sys.stdin if l.strip()]))' \
    2>/dev/null || echo '[]')"

# Try to spot touches on files that should only change through the
# harness (run-state.json, .sprintfoundry/eval-results/eval-result-*.md,
# sprint-contract.md) so
# auditors can quickly find manual-override candidates.
SENSITIVE_JSON="$(python3 - "$FILES_JSON" <<'PY' 2>/dev/null || echo '[]'
import json, re, sys
files = json.loads(sys.argv[1])
sensitive = []
for f in files:
    if f == "run-state.json":
        sensitive.append(f)
    elif f == "claude-progress.txt":
        sensitive.append(f)
    elif re.match(r"^eval-result-\d+\.md$", f):
        sensitive.append(f)
    elif re.match(r"^\.sprintfoundry/eval-results/eval-result-\d+\.md$", f):
        sensitive.append(f)
    elif f == "sprint-contract.md":
        sensitive.append(f)
    elif f == "sprint-fence.json":
        sensitive.append(f)
print(json.dumps(sensitive))
PY
)"

python3 - "$SHA" "$SUBJECT" "$AUTHOR" "$FILES_JSON" "$SENSITIVE_JSON" <<'PY' 2>/dev/null || true
import json, sys, datetime, pathlib

sha, subject, author, files_json, sensitive_json = sys.argv[1:6]
record = {
    "ts": datetime.datetime.now(datetime.timezone.utc).astimezone().isoformat(timespec="seconds"),
    "event": "commit_recorded",
    "actor": "post-commit",
    "payload": {
        "sha": sha,
        "subject": subject,
        "author": author,
        "files": json.loads(files_json),
        "sensitive_files": json.loads(sensitive_json),
    },
}
with pathlib.Path("harness-audit.ndjson").open("a", encoding="utf-8") as f:
    f.write(json.dumps(record, ensure_ascii=False) + "\n")
PY
